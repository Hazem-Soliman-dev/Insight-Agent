# Database
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# AI Provider - Groq
GROQ_API_KEY="your_groq_api_key_here"

# Server Configuration
PORT=3001
NODE_ENV=production
REDIS_URL="redis://default:password@host:port"

# CORS Configuration (comma-separated list of allowed origins)
# For development: http://localhost:3000,http://127.0.0.1:3000
# For production: https://your-frontend-domain.com
# For all origins (not recommended for production): *
ALLOWED_ORIGINS=https://your-frontend-domain.com
FRONTEND_URL=https://your-production-frontend.com

# Clerk Authentication
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Polar Payments
POLAR_ACCESS_TOKEN=your_polar_access_token_here
POLAR_ORGANIZATION_ID=your_polar_organization_id_here
POLAR_WEBHOOK_SECRET=your_polar_webhook_secret_here
POLAR_STARTER_PRODUCT_ID=your_starter_product_id
POLAR_GROWTH_PRODUCT_ID=your_growth_product_id
POLAR_POWER_PRODUCT_ID=your_power_product_id
